{
  "name": "radiotranslator",
  "version": "1.0.0",
  "description": "电台实时收听、字幕和翻译平台",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "db:migrate": "node server/database/migrate.js",
    "test": "jest"
  },
  "keywords": ["radio", "translation", "subtitle", "streaming"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2",
    "socket.io": "^4.6.2",
    "axios": "^1.6.2",
    "multer": "^1.4.5-lts.1",
    "stripe": "^14.10.0",
    "node-fetch": "^2.7.0",
    "fluent-ffmpeg": "^2.1.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  }
}
